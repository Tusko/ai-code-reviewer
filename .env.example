# Your GitLab instance URL (default: https://gitlab.com)
GITLAB_URL=https://gitlab.com

# A Personal Access Token (PAT) with `api` scope
GITLAB_TOKEN=your_gitlab_token_here

# A secret token you set when creating the Webhook (optional but recommended)
WEBHOOK_SECRET=your_secret_token_here

# The Ollama model to use (default: codellama)
# You can swap `codellama` for `llama3`, `mistral`, etc., in `.env` and here
OLLAMA_MODEL=codellama

# Your Cloudflare Tunnel token
TUNNEL_TOKEN=your_tunnel_token_here
